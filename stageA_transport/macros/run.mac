# Stage A — batch production run: transport protons, capture beta+ emitters,
# write data/emitters.csv + data/run_meta.csv.

/run/numberOfThreads 18

# Phantom material (must precede /run/initialize). Soft tissue is the clinically
# representative, 15O-dominated source; swap for G4_PLEXIGLASS (PMMA, carbon-rich
# benchmark) or G4_WATER (pure-15O extreme).
/stageA/phantom/material G4_TISSUE_SOFT_ICRP
/run/initialize

# Base output dir (relative to build/). Stage A appends <geometry>_<beam>_<N>,
# so this run lands in data/runs/cylinder_pencil_1e5/.
/stageA/output/dir ../../data/runs

# Reproducibility: master seed (workers get deterministic per-event seeds).
/random/setSeeds 12345 67890

# 1e5 protons is a quick validation (~tens of seconds); raise to 1e6+ for
# better per-isotope statistics.
/run/printProgress 20000
/run/beamOn 100000
